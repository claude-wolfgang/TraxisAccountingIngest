{
  "manifest_version": 3,
  "name": "Traxis Label Printer",
  "version": "1.5.0",
  "description": "Print material, COTS, equipment, box, and user labels from ProShop pages via Brother PT-P700",
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "permissions": ["activeTab"],
  "host_permissions": [
    "https://traxismfg.adionsystems.com/*",
    "http://10.1.1.242:5002/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://traxismfg.adionsystems.com/procnc/workorders/*"],
      "js": ["lib/qrcode.min.js", "src/label-generator.js", "src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://traxismfg.adionsystems.com/procnc/ots/*"],
      "js": ["lib/qrcode.min.js", "src/cots-label-generator.js", "src/cots-content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://traxismfg.adionsystems.com/procnc/equipment/*"],
      "js": ["lib/qrcode.min.js", "src/equipment-label-generator.js", "src/equipment-content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://traxismfg.adionsystems.com/procnc/workorders/*"],
      "js": ["lib/qrcode.min.js", "src/box-label-generator.js", "src/box-content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://traxismfg.adionsystems.com/procnc/users/*"],
      "js": ["lib/qrcode.min.js", "src/user-label-generator.js", "src/user-content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://traxismfg.adionsystems.com/procnc/tools/*"],
      "js": ["lib/qrcode.min.js", "src/tool-label-generator.js", "src/tool-content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/*", "lib/*", "assets/*"],
      "matches": ["https://traxismfg.adionsystems.com/*"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
