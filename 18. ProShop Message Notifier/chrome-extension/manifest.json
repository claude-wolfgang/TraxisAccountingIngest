{
  "manifest_version": 3,
  "name": "ProShop Message Notifier",
  "version": "1.0",
  "description": "Alerts when you receive a new ProShop message",
  "permissions": ["storage", "alarms", "notifications"],
  "host_permissions": [
    "https://traxismfg.adionsystems.com/*",
    "http://10.1.1.71:5050/*"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "ProShop Message Notifier"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [{
    "matches": ["https://traxismfg.adionsystems.com/procnc/*"],
    "js": ["content/content.js"],
    "css": ["content/notification.css"],
    "run_at": "document_idle"
  }],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
